# OpenAI-compatible API settings
OPENAI_API_KEY=
OPENAI_BASE_URL=

# FilingDelta runtime settings
FILINGDELTA_LLM_MODEL=gpt-4.1-mini
FILINGDELTA_EMBED_MODEL=text-embedding-3-small
FILINGDELTA_USE_LLAMA_PARSE=1
FILINGDELTA_LLAMA_PARSE_TIER=agentic
FILINGDELTA_LLAMA_PARSE_VERSION=latest
FILINGDELTA_LLAMA_EXTRACT_TIER=agentic
FILINGDELTA_APP_HOST=127.0.0.1
FILINGDELTA_APP_PORT=8000

# Optional external services
LLAMA_CLOUD_API_KEY=
LLAMA_CLOUD_BASE_URL=
FILINGDELTA_QDRANT_PATH=./data/indexes/qdrant
